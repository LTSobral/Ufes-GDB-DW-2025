# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=airflow
POSTGRES_HOST=postgres

# Airflow User (created during init)
_AIRFLOW_WWW_USER_USERNAME=airflow-dev
_AIRFLOW_WWW_USER_PASSWORD=your_secure_password_here

# Airflow UID (optional, used for file permissions)
AIRFLOW_UID=50000

# Airflow configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__API_AUTH__JWT_SECRET=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

COMPOSE_PROJECT_NAME=ufes-dw

MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=your_secure_password_here
MONGO_INITDB_DATABASE=root

HOSTNAME=ufes
AIRFLOW_GID=7777
AIRFLOW_USER=ufes
AIRFLOW_PASSWORD=your_secure_password_here
AIRFLOW_IMAGE_NAME=airflow/airflow-ufes:latest
VERSION=1.1.0
AIRFLOW_PROJ_DIR="."
POSTGRES_VOLUME=postgres-db-volume

NETWORK="network-airflow-ufes-dw"